---
export const prerender = false;
import { getPostBySlug } from '../../lib/directus-ql';
import Layout from '../../layouts/Layout.astro';
import MarkdownPostLayout from '../../layouts/MarkdownPostLayout.astro';

const { postdirectus } = Astro.params;

const data = await getPostBySlug(postdirectus);

const post = data;
---
{post ? (
    <MarkdownPostLayout 
      frontmatter={{ 
        title: post.title, 
        pubDate: new Date(post.date),
        author: post.author?.name,
        tags: []
      }}>
      <div set:html={post.content} />
      </MarkdownPostLayout>
  ) : (
    <p>Post not found.</p>
)}